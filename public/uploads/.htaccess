# Never execute PHP inside the uploads directory.

php_flag engine off

<IfModule mod_php.c>
    php_admin_flag engine off
</IfModule>

# Deny direct access to any executable script extensions.
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|pht|phar|cgi|pl)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent handlers from running scripts even if the flag above is ignored.
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .php8 .pht .phar
RemoveType .php .phtml .php3 .php4 .php5 .php7 .php8 .pht .phar

Options -Indexes -ExecCGI
