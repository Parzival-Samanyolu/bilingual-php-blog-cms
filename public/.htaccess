# My Blog — front controller rewrite + security headers

<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the site lives in a subdirectory, uncomment and adjust:
    # RewriteBase /

    # Do not rewrite requests for existing files or directories.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else through the front controller.
    RewriteRule ^ index.php [L]
</IfModule>

# ---------------------------------------------------------------------------
# Block direct access to sensitive files and directories.
# ---------------------------------------------------------------------------
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Older Apache (2.2) fallback for the .env rule above.
<IfModule !mod_authz_core.c>
    <FilesMatch "^\.env">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

RedirectMatch 404 ^/cache/
RedirectMatch 404 ^/database/

# ---------------------------------------------------------------------------
# Security headers.
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Disable directory listing.
Options -Indexes
