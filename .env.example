# real.com.tr — environment configuration
# Copy this file to .env and fill in the values. Never commit the real .env.

# Application: "production", "development" or "local"
APP_ENV=
# Absolute base URL, no trailing slash, e.g. https://example.com
APP_URL=
# Sub-path when hosted under a subfolder, e.g. "/blog" (leave empty at domain root)
APP_BASE=

# Database (MySQL 8.x)
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# Google OAuth 2.0 credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Outgoing mail "From" address used by PHP mail()
MAIL_FROM=
